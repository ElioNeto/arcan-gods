# ============================================================
# Arcan Gods — Server Dockerfile (Development)
# Com hot-reload via tsx watch
# ============================================================

FROM node:20-alpine
WORKDIR /app

# Copy root workspace config
COPY package.json tsconfig.base.json ./

# Copy all package configs
COPY packages/shared/package.json packages/shared/
COPY packages/server/package.json packages/server/

# Install dependencies
RUN npm install

# Build shared (needed for module resolution)
COPY packages/shared/ packages/shared/
RUN npm run build -w packages/shared

# Copy server source (volume mount overrides this at runtime)
COPY packages/server/ packages/server/

EXPOSE 3001

# Use tsx watch for hot-reload
CMD ["npm", "run", "dev", "-w", "packages/server"]
