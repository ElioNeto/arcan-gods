# ============================================================
# Arcan Gods — Client Dockerfile (Development)
# Com hot-reload via Vite
# ============================================================

FROM node:20-alpine
WORKDIR /app

# Copy root workspace config + lockfile for reproducible installs
COPY package.json package-lock.json tsconfig.base.json ./

# Copy ALL workspace package.json files (npm ci needs them all)
COPY packages/shared/package.json packages/shared/
COPY packages/server/package.json packages/server/
COPY packages/client/package.json packages/client/

# Install ALL workspace dependencies (includes zod from shared)
RUN npm ci --no-audit --no-fund

# Build shared (needed for module resolution)
COPY packages/shared/ packages/shared/
RUN npm run build -w packages/shared

# Copy client source (volume mount overrides this at runtime)
COPY packages/client/ packages/client/

EXPOSE 5173

# Use npm workspace dev script (resolves paths correctly for Vite root)
# Use npm workspace dev script — resolves CWD to packages/client/ so Vite root='.' works
# HOST=0.0.0.0 must be set in docker-compose env for external access
CMD ["npm", "run", "dev", "-w", "packages/client", "--", "--host", "0.0.0.0"]
