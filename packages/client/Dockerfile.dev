# ============================================================
# Arcan Gods — Client Dockerfile (Development)
# Com hot-reload via Vite
# ============================================================

FROM node:20-alpine
WORKDIR /app

# Copy root workspace config
COPY package.json tsconfig.base.json ./

# Copy all package configs
COPY packages/shared/package.json packages/shared/
COPY packages/client/package.json packages/client/

# Install dependencies
RUN npm install

# Build shared (needed for module resolution)
COPY packages/shared/ packages/shared/
RUN npm run build -w packages/shared

# Copy client source (volume mount overrides this at runtime)
COPY packages/client/ packages/client/

EXPOSE 5173

# Use Vite dev server with host 0.0.0.0 for Docker
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
